{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "ClickBook",
  "version": "1.5.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "author": "Junpapapo",
  "homepage_url": "https://github.com/Junpapapo/ClickBook",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "bookmarks",
    "browsingData",
    "scripting",
    "unlimitedStorage",
    "contextMenus",
    "tabGroups",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.github.com/*",
    "https://wikimedia.org/*",
    "https://*.wikipedia.org/*",
    "https://huggingface.co/*",
    "https://hacker-news.firebaseio.com/*"
  ],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "__MSG_saveCurrentTab__"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/buddy/content-entry.ts"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "buddies/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
