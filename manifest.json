{
  "manifest_version": 3,
  "name": "ClickBook",
  "short_name": "ClickBook",
  "version": "1.2.0",
  "description": "Save, organize, and manage bookmarks by category with one click. Includes browsing data cleanup tools.",
  "author": "Junpapapo",
  "homepage_url": "https://github.com/Junpapapo/ClickBook",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "bookmarks",
    "browsingData",
    "scripting"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://wikimedia.org/*",
    "https://*.wikipedia.org/*",
    "https://huggingface.co/*",
    "https://hacker-news.firebaseio.com/*"
  ],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "현재 탭을 북마크로 저장"
    }
  }
}
